# RG35XX-SP 一期补丁:defconfig 默认禁用但需要的驱动
#
# 来源:2026-05-20 串口实测发现以下平台 device probe 后 driver 没装
#   - AXP717 电源管理(P0-7):battery / USB power / ADC / 电源键
#   - 音频(P0-6):sun4i-codec machine driver 没编 → 没声卡
#
# 用法:在 build 时 cat 此文件到 .config 末尾再 make olddefconfig

# === AXP20X (mainline 对应 AXP717) 子驱动 ===
CONFIG_AXP20X_POWER=m            # USB power supply
CONFIG_AXP20X_ADC=m              # 内部 ADC(电池电压/温度)
CONFIG_BATTERY_AXP20X=m          # 电池 SOC
CONFIG_INPUT_AXP20X_PEK=m        # 电源键 KEY_POWER

# === Audio ===
CONFIG_SND_SUN4I_CODEC=m         # H616/H700 audio machine + platform driver

# === WiFi: Realtek RTL8821CS (SDIO) ===
# 设备实测:mmc1: new high speed SDIO card at address 0001 ✓
# 但 mainline RTW88_8821CS 默认 defconfig 未启用
CONFIG_RTW88=m
CONFIG_RTW88_CORE=m
CONFIG_RTW88_SDIO=m
CONFIG_RTW88_8821C=m
CONFIG_RTW88_8821CS=m

# === Bluetooth: 显式弃用(2026-05-21 决策)===
# 详见 ISSUES.md P0-2:mainline 7.0.9 对 8821CS BT 支持不完整,
# 触发 chip 第二次 setup 会拉死整个 combo chip,连带 WiFi 一起挂。
# 掌机不依赖 BT,直接关掉 BT 子系统,避免任何 UART/serdev 路径起来。
CONFIG_BT=n
# 下列条目跟着 BT=n 自动 disable,留作显式注释方便回查
# CONFIG_BT_HCIUART
# CONFIG_BT_HCIUART_H4
# CONFIG_BT_HCIUART_3WIRE
# CONFIG_BT_HCIUART_RTL
# CONFIG_BT_RTL
# CONFIG_BT_BNEP

# === cpufreq autoload(改 builtin,避免 udev 不触发)===
CONFIG_ARM_ALLWINNER_SUN50I_CPUFREQ_NVMEM=y

# === IOMMU(P0-4 panfrost defer probe -110)===
# 2026-05-22 实测:`allwinner,sun50i-h616-iommu` 节点在 DT,但 7.0.9 defconfig
# 未启 SUN50I_IOMMU,/lib/modules/7.0.9/kernel/drivers/iommu/ 只有 apple-dart。
# panfrost gpu@1800000 声明 iommus = <&iommu>,等不到 IOMMU driver → -ETIMEDOUT。
# 必须 builtin(=y) — panfrost 在 boot 早期 probe,模块加载时机过晚。
CONFIG_SUN50I_IOMMU=y

# === H616 PRCM PPU(P0-4 panfrost defer probe -110 第二根因)===
# 2026-05-23 实测:IOMMU 已 builtin 且绑定,但 panfrost 仍 -110。
# 根因:GPU DT 节点有 power-domains = <&prcm_ppu 2>,但 PPU 驱动未编译。
# Kconfig 明确说明:"This is required to enable the Mali GPU in the H616 SoC"。
# 必须 builtin(=y) — GPU 电源域在 panfrost probe 之前必须 ready。
CONFIG_SUN50I_H6_PRCM_PPU=y

# === Panel / LCD(P0-3,方案 A:LCD-only + GPIO 背光)===
# 2026-05-22 加:已通过 Batocera 11 个子 patch 上完 DE33/TCON/dts 主体,
# 加自家 patch 36df6ca2b 给 NV3052C 驱动注册 anbernic,rg35xx-sp-panel 变体。
# 见 DISPLAY.md §1.4 / §4.8 / §10.3。
CONFIG_DRM_PANEL_NEWVISION_NV3052C=m
CONFIG_SPI_GPIO=m
CONFIG_BACKLIGHT_GPIO=m

# === DRM debug(排查 P0-3 屏黑 component bind 问题)===
CONFIG_DRM_DEBUG=y
CONFIG_DRM_DEBUG_DRIVER=y

# === TF2 卡槽 exFAT(P1-20:第二 SD 卡常用 exFAT 格式)===
CONFIG_EXFAT_FS=y

# === binfmt_misc(P1-5:模拟器需要 /proc/sys/fs/binfmt_misc)===
CONFIG_BINFMT_MISC=y

# === SO_PASSSEC(P1-6:systemd socket 报 SO_PASSSEC failed)===
CONFIG_SECURITY_NETWORK=y

# === CMA 加大至 64 MiB(cedrus VPU 解码帧需要 + GPU 共享)====
# 2026-05-24:32 MiB 碎片化后 cedrus v4l2-request 连 338 页(~1.35 MiB)都分不出
CONFIG_CMA_SIZE_MBYTES=64

# === DMA-buf heaps(cedrus V4L2-request 硬解必需)===
# FFmpeg RPi v4l2-request 补丁通过 /dev/dma_heap/system 分配 DMA-buf。
# 未启用时回退 MMap,cedrus capture queue 不支持 → segfault。
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_DMABUF_HEAPS_SYSTEM=y

# === Cedrus VPU (Allwinner H616 V4L2 硬解驱动)===
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_PLATFORM_SUPPORT=y
CONFIG_V4L2_MEM2MEM_DRIVERS=y
CONFIG_VIDEO_SUNXI=y
CONFIG_VIDEO_SUNXI_CEDRUS=m

# === Kernel release 保持干净的 "7.0.9"(不附加 git 短 hash)===
# 2026-05-22 加:linux-7.0.9 起了 git 后,LOCALVERSION_AUTO=y 会让 kernel
# release 变成 "7.0.9-g7f77..."(setlocalversion 脚本探到 git 仓库),
# modules 装到 /lib/modules/7.0.9-g7f77.../ — 跟 c_ssh_deploy.sh 内
# KVER=7.0.9 hardcode 路径对不上。关掉自动 git 标。
# CONFIG_LOCALVERSION_AUTO is not set
