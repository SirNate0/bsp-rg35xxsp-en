# RG35XX-SP phase 1 patch: drivers disabled by defconfig but needed
#
# Source: 2026-05-20 serial test found the following platform device probe after driver not loaded
#   - AXP717 PMIC(P0-7):battery / USB power / ADC / power key
#   - Audio(P0-6):sun4i-codec machine driver not built -> no sound card
#
# Usage: during build, cat this file to .config tail then make olddefconfig

# === AXP20X (mainline corresponds to AXP717) sub-drivers ===
CONFIG_AXP20X_POWER=m            # USB power supply
CONFIG_AXP20X_ADC=m              # internal ADC(battery voltage/temperature)
CONFIG_BATTERY_AXP20X=m          # battery SOC
CONFIG_INPUT_AXP20X_PEK=m        # power key KEY_POWER

# === Audio ===
CONFIG_SND_SUN4I_CODEC=m         # H616/H700 audio machine + platform driver

# === WiFi: Realtek RTL8821CS (SDIO) ===
# Hardware tested: mmc1: new high speed SDIO card at address 0001 ✓
# But mainline RTW88_8821CS not enabled in default defconfig
CONFIG_RTW88=m
CONFIG_RTW88_CORE=m
CONFIG_RTW88_SDIO=m
CONFIG_RTW88_8821C=m
CONFIG_RTW88_8821CS=m

# === Bluetooth: explicitly deprecated (2026-05-21 decision)===
# See ISSUES.md P0-2:mainline 7.0.9 8821CS BT support incomplete,
# triggering chip second setup kills the entire combo chip, taking WiFi down too.
# Handheld does not rely on BT, disable BT subsystem directly to avoid any UART/serdev path.
CONFIG_BT=n
# The following entries auto-disable with BT=n, kept as explicit comments for traceability
# CONFIG_BT_HCIUART
# CONFIG_BT_HCIUART_H4
# CONFIG_BT_HCIUART_3WIRE
# CONFIG_BT_HCIUART_RTL
# CONFIG_BT_RTL
# CONFIG_BT_BNEP

# === cpufreq autoload(changed to builtin to avoid udev not triggering)===
CONFIG_ARM_ALLWINNER_SUN50I_CPUFREQ_NVMEM=y

# === IOMMU(P0-4 panfrost defer probe -110)===
# 2026-05-22 tested:`allwinner,sun50i-h616-iommu` node in DT, but 7.0.9 defconfig
# does not enable SUN50I_IOMMU,/lib/modules/7.0.9/kernel/drivers/iommu/ only has apple-dart.
# panfrost gpu@1800000 declares iommus = <&iommu>, does not get IOMMU driver -> -ETIMEDOUT.
# Must be builtin(=y) — panfrost probes early in boot, module loading is too late.
CONFIG_SUN50I_IOMMU=y

# === H616 PRCM PPU(P0-4 panfrost defer probe -110 second root cause)===
# 2026-05-23 tested:IOMMU already builtin and bound, but panfrost still -110.
# Root cause:GPU DT node has power-domains = <&prcm_ppu 2>, but PPU driver not compiled.
# Kconfig explicitly states:"This is required to enable the Mali GPU in the H616 SoC".
# Must be builtin(=y) — GPU power domain must be ready before panfrost probe.
CONFIG_SUN50I_H6_PRCM_PPU=y

# === Panel / LCD(P0-3,plan A:LCD-only + GPIO backlight)===
# 2026-05-22 added:DE33/TCON/dts main body already upstreamed via Batocera 11 sub-patches,
# plus custom patch 36df6ca2b adding anbernic,rg35xx-sp-panel variant to NV3052C driver.
# See DISPLAY.md §1.4 / §4.8 / §10.3.
CONFIG_DRM_PANEL_NEWVISION_NV3052C=m
CONFIG_SPI_GPIO=m
CONFIG_BACKLIGHT_GPIO=m

# === DRM debug(for diagnosing P0-3 black screen component bind issue)===
CONFIG_DRM_DEBUG=y
CONFIG_DRM_DEBUG_DRIVER=y

# === TF2 slot exFAT(P1-20:second SD card commonly uses exFAT)===
CONFIG_EXFAT_FS=y

# === binfmt_misc(P1-5:emulators need /proc/sys/fs/binfmt_misc)===
CONFIG_BINFMT_MISC=y

# === SO_PASSSEC(P1-6:systemd socket reports SO_PASSSEC failed)===
CONFIG_SECURITY_NETWORK=y

# === CMA increased to 64 MiB(cedrus VPU decode frames need + GPU sharing)====
# 2026-05-24:32 MiB fragmentation causes cedrus v4l2-request to fail allocating even 338 pages(~1.35 MiB)
CONFIG_CMA_SIZE_MBYTES=64

# === DMA-buf heaps(required for cedrus V4L2-request hardware decoding)===
# FFmpeg RPi v4l2-request patches allocate DMA-buf via /dev/dma_heap/system.
# When not enabled, falls back to MMap, cedrus capture queue does not support that -> segfault.
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_DMABUF_HEAPS_SYSTEM=y

# === Cedrus VPU (Allwinner H616 V4L2 hardware decode driver)===
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_PLATFORM_SUPPORT=y
CONFIG_V4L2_MEM2MEM_DRIVERS=y
CONFIG_VIDEO_SUNXI=y
CONFIG_VIDEO_SUNXI_CEDRUS=m

# === Kernel release keeps clean "7.0.9"(no git short hash appended)===
# 2026-05-22 added:after linux-7.0.9 gets git initialized, LOCALVERSION_AUTO=y makes kernel
# release become "7.0.9-g7f77..."(setlocalversion script detects git repo),
# modules install to /lib/modules/7.0.9-g7f77.../ — mismatches the KVER=7.0.9 hardcoded path
# inside c_ssh_deploy.sh. Disable automatic git suffix.
# CONFIG_LOCALVERSION_AUTO is not set
