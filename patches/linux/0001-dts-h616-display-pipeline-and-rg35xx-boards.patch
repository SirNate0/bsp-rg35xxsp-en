+
+/*
+ * Anbernic RG35XX-SP uses a different NV3052C timing tuning than Plus/H.
+ * Vendor BSP driver name fog_fj035fhd05_v1, htotal=720 / vtotal=560 / 24 MHz
+ * (vs Plus htotal=770 / vtotal=520). Same WL-355608-A8 panel module + same
+ * SPI init sequence, only display_mode differs. See DISPLAY.md §4.8 / §8.2.
+ */
+
+&panel {
+	compatible = "anbernic,rg35xx-sp-panel";
+};
+
+/* USB peripheral — gadget mode for network/file transfer */
+&usbotg {
+	dr_mode = "peripheral";
+};
+
+&usbphy {
+	dr_mode = "peripheral";
+};
+
+/*
+ * EHCI0/OHCI0 与 MUSB gadget 共用 PHY0,同时启用会导致 PHY 被
+ * 切到 host 模式而破坏 gadget。键盘本身需 OTG 转接头,暂禁用。
+ * 待解决 PHY0 多控制器共存后再启用。
+ */
+&ehci0 {
+	status = "disabled";
+};
+
+&ohci0 {
+	status = "disabled";
+};
+
+/* TF2 — second SD card slot (P1-20) */
+&mmc2 {
+	vmmc-supply = <&reg_tf2_vdd>;
+	vqmmc-supply = <&reg_cldo2>;	/* 3.3V, unused on this board */
+	cd-gpios = <&pio 4 22 GPIO_ACTIVE_LOW>; /* PE22 */
+	bus-width = <4>;
+	no-sdio;
+	no-mmc;
+	status = "okay";
+};
